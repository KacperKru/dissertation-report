@InProceedings{10.1007/978-3-642-39473-7_39,
   author="Ancient, Claire
   and Good, Alice",
   editor="Stephanidis, Constantine",
   title="Issues with Designing Dementia-Friendly Interfaces",
   booktitle="HCI International 2013 - Posters' Extended Abstracts",
   year="2013",
   publisher="Springer Berlin Heidelberg",
   address="Berlin, Heidelberg",
   pages="192--196",
   abstract="People with dementia are a rapidly growing demographic. In a world which is increasingly dependent on computing, this large group of people is becoming technologically isolated, due to the ill-suited design of interfaces. This paper looks at the possible 'roadblocks' which need to be considered when designing interfaces in order to ensure they are dementia-friendly. By considering the unique needs of a person with dementia, designers can ensure that their software is accessible to this demographic, hence potentially reducing the feelings of technological exclusion.",
   isbn="978-3-642-39473-7"
}
